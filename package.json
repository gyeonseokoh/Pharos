		"clsx": "^2.1.1",
		"gantt-task-react": "^0.3.9",
		"lucide-react": "^1.8.0",
		"obsidian": "latest",
		"openai": "^4.67.1",
		"react": "^18.3.1",
		"react-dom": "^18.3.1",
		"tailwind-merge": "^3.5.0",
		"zod": "^3.23.8"
