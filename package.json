{
	"name": "pharos",
	"version": "0.1.0",
	"description": "AI-powered project manager for Obsidian — roadmap automation, meeting intelligence, and real-time progress tracking.",
	"main": "main.js",
	"type": "module",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"version": "node version-bump.mjs && git add manifest.json versions.json",
		"lint": "eslint ."
	},
	"keywords": [
		"obsidian",
		"project-management",
		"ai",
		"roadmap",
		"collaboration"
	],
	"license": "0-BSD",
	"devDependencies": {
		"@eslint/js": "9.30.1",
		"@types/node": "^16.11.6",
		"@types/react": "^18.3.12",
		"@types/react-dom": "^18.3.1",
		"autoprefixer": "^10.5.0",
		"esbuild": "0.25.5",
		"esbuild-plugin-postcss2": "^0.1.2",
		"eslint-plugin-obsidianmd": "0.1.9",
		"globals": "14.0.0",
		"jiti": "2.6.1",
		"postcss": "^8.5.10",
		"tailwindcss": "^3.4.19",
		"tslib": "2.4.0",
		"typescript": "^5.8.3",
		"typescript-eslint": "8.35.1"
	},
	"dependencies": {
		"@fontsource/pretendard": "^5.2.5",
